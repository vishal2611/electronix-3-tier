pipeline {
    agent {
        label 'electronix'
    }

    stages {
        stage('Creating Database') {
            steps {
                sh '''
                    python3 scripts/create_db.py
                '''
            }
        }
    }

    post {
        success {
            echo 'Database creation Successful ✅'
        }

        failure {
            echo 'Database Creation Failed ❌'
        }
    }
}